FROM --platform=linux/amd64 ubuntu:22.04

# Install build essentials
RUN apt-get update && apt-get install -y \
    python3 \
    python3-distutils \
    build-essential \
    curl \
    git

# Install Node 18 (nexe-compatible)
RUN curl -fsSL https://deb.nodesource.com/setup_18.x | bash - \
    && apt-get install -y nodejs

# Create working directory
WORKDIR /app

# Copy your project
COPY . .

# Install dependencies
RUN npm install

# Build TypeScript
RUN npm run build

# Build SMAGE binary with nexe
RUN npx nexe ./dist/smage/smage.js \
    --build \
    --python /usr/bin/python3 \
    --output smage \
    --bundle \
    --target linux-x64-18.0.0 \
    --resource "./dist/ha_mcp/**/*" \
    --resource "./dist/ha_core/**/*" \
    --resource "./dist/ha_wrap/**/*" \
    --resource "./dist/ha_cli/**/*" \
    --resource "./dist/ha_proxy/**/*" \
    --resource "./dist/ha_learn/**/*" \
    --resource "./dist/smage/**/*"
