{
    "compilerOptions": {
        "rootDir": ".",
        "outDir": "dist",
        "esModuleInterop": true,
        "resolveJsonModule": true,

        "module": "esnext",
        "target": "esnext",
        "types": ["node", "express"],
        "lib": ["esnext"],

        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,

        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,

        "moduleResolution": "node",
        "rewriteRelativeImportExtensions": true,

        "strict": true,
        "ignoreDeprecations": "6.0",
        "noUncheckedSideEffectImports": true,
        "skipLibCheck": true
    },
    "include": [
        "ha_core/**/*",
        "ha_proxy/**/*",
        "ha_mcp/**/*",
        "ha_wrap/**/*",
        "ha_cli/**/*",
        "ha_docs/**/*",
        "ha_learn/**/*"
    ],
    "exclude": ["node_modules"],
    "paths": {
        "@core/*": ["ha_core/*"],
        "@proxy/*": ["ha_proxy/*"],
        "@mcp/*": ["ha_mcp/*"],
        "@wrap/*": ["ha_wrap/*"],
        "@docs/*": ["ha_docs/*"],
        "@learn/*": ["ha_learn/*"],
        "@cli/*": ["ha_cli/*"]
    }
}
